{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=dev-domiki;Username=postgres;Password=postgres"
  },
  "Oidc": {
    "Scheme": "",
    "DisplayName": "",
    "Authority": "",
    "ClientId": "",
    "ClientSecret": ""
  },
  "Demo": {
    "UserName": "demo",
    "Email": "demo@domiki.local",
    "Password": "demo"
  },
  "Push": {
    "VapidPublicKey": "",
    "VapidPrivateKey": "",
    "Subject": ""
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/domiki-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
