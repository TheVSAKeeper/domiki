<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color"
          content="#40632f" />
    <title>@ViewData["Title"] – Домики</title>
    <link rel="preconnect"
          href="https://fonts.googleapis.com" />
    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Golos+Text:wght@400;600;700&family=Press+Start+2P&display=swap"
          rel="stylesheet" />
    <link rel="stylesheet"
          href="~/css/auth.css"
          asp-append-version="true" />
</head>
<body>
    <main class="auth-page">
        @RenderBody()
    </main>
    @await RenderSectionAsync("Scripts", false)
</body>
</html>
