@page
@model ResetPasswordConfirmationModel

@{
    ViewData["Title"] = "Пароль обновлён";
}

<div class="auth-card">
    <a class="auth-brand"
       href="~/">DOMIKI</a>
    <h1 class="auth-title">Пароль обновлён</h1>

    <p class="auth-lead">Пароль успешно изменён. Теперь можно войти с новым паролем.</p>

    <div class="auth-links">
        <a asp-page="./Login">Войти →</a>
        <a href="~/">На главную</a>
    </div>
</div>
