@page
@model ResetPasswordModel

@{
    ViewData["Title"] = "Сброс пароля";
}

<div class="auth-card">
    <a class="auth-brand" href="~/">DOMIKI</a>
    <h1 class="auth-title">Новый пароль</h1>

    <div asp-validation-summary="ModelOnly" class="auth-error" role="alert"></div>

    <form method="post">
        <input asp-for="Input.Code" type="hidden" />
        <div class="auth-field">
            <label asp-for="Input.Email" class="auth-label">Почта</label>
            <input asp-for="Input.Email" class="auth-input" autocomplete="username" aria-required="true" required placeholder="name@example.com" />
            <span asp-validation-for="Input.Email" class="field-error"></span>
        </div>
        <div class="auth-field">
            <label asp-for="Input.Password" class="auth-label">Пароль</label>
            <input asp-for="Input.Password" class="auth-input" type="password" autocomplete="new-password" aria-required="true" required placeholder="••••••••" />
            <span asp-validation-for="Input.Password" class="field-error"></span>
        </div>
        <div class="auth-field">
            <label asp-for="Input.ConfirmPassword" class="auth-label">Повтор пароля</label>
            <input asp-for="Input.ConfirmPassword" class="auth-input" type="password" autocomplete="new-password" aria-required="true" required placeholder="••••••••" />
            <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
        </div>
        <button type="submit" class="btn-game" style="width: 100%;">Сохранить пароль</button>
    </form>

    <div class="auth-links">
        <a asp-page="./Login">← Ко входу</a>
        <a href="~/">На главную</a>
    </div>
</div>
