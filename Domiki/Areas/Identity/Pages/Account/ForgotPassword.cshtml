@page
@model ForgotPasswordModel

@{
    ViewData["Title"] = "Восстановление пароля";
}

<div class="auth-card">
    <a class="auth-brand"
       href="~/">DOMIKI</a>
    <h1 class="auth-title">Забыли пароль?</h1>

    <p class="auth-lead">Укажите почту – пришлём ссылку для сброса пароля.</p>

    <div asp-validation-summary="ModelOnly"
         class="auth-error"
         role="alert"></div>

    <form method="post">
        <div class="auth-field">
            <label asp-for="Input.Email"
                   class="auth-label">Почта</label>
            <input asp-for="Input.Email"
                   class="auth-input"
                   autocomplete="username"
                   aria-required="true"
                   required
                   placeholder="name@example.com" />
            <span asp-validation-for="Input.Email"
                  class="field-error"></span>
        </div>
        <button type="submit"
                class="btn-game"
                style="width: 100%;">Прислать ссылку
        </button>
    </form>

    <div class="auth-links">
        <a asp-page="./Login">← Ко входу</a>
        <a href="~/">На главную</a>
    </div>
</div>
