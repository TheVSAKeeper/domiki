@page
@model ForgotPasswordConfirmationModel

@{
    ViewData["Title"] = "Проверьте почту";
}

<div class="auth-card">
    <a class="auth-brand" href="~/">DOMIKI</a>
    <h1 class="auth-title">Проверьте почту</h1>

    <p class="auth-lead">Если такая почта зарегистрирована, мы отправили на неё ссылку для сброса пароля.</p>

    <div class="auth-links">
        <a asp-page="./Login">← Ко входу</a>
        <a href="~/">На главную</a>
    </div>
</div>
